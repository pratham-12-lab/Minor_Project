# Copy this file to .env and fill in your secrets and config values

PORT=8000
MONGO_URI=mongodb://mongodb:27017/job_portal
FRONTEND_URL=http://localhost
SECRET_KEY=your_jwt_secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
APP_NAME=Job Portal
GEMINI_API_KEY=your_gemini_api_key
